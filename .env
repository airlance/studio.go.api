# Database Configuration
# DSN for GORM (Postgres)
# Example: host=localhost user=postgres password=postgres dbname=studio port=5432 sslmode=disable
DB_DSN="host=db user=postgres password=postgres dbname=postgres port=5432 sslmode=disable"

# Logging Configuration
# Levels: debug, info, warn, error
LOG_LEVEL=debug

# Server Configuration
# PORT=8080
# CORS_ALLOWED_ORIGINS=http://dashboard.studio.localhost

# Storage Configuration
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY_ID=studio-minio
STORAGE_SECRET_ACCESS_KEY=studio-minio
STORAGE_BUCKET=studio
# STORAGE_PUBLIC_BASE_URL is used to generate presigned URLs accessible from the browser
# When running locally with Docker, this should be http://localhost:9000
STORAGE_PUBLIC_BASE_URL=http://minio.studio.localhost
# STORAGE_USE_SSL=false
# STORAGE_FORCE_PATH_STYLE=true

# Kratos Configuration
# KRATOS_ADMIN_URL=http://kratos:4434
# KRATOS_PUBLIC_URL=http://kratos:4433

# RabbitMQ Configuration
RABBITMQ_URL=amqp://rbmq:rbmq@localhost:5672/

# Mailer Configuration
MAILER_PROVIDER=smtp
MAILER_FROM=no-reply@studio.localhost
MAILER_HOST=mailhog
MAILER_PORT=1025
MAILER_USERNAME=
MAILER_PASSWORD=

SERVER_DASHBOARD_URL=http://dashboard.studio.localhost